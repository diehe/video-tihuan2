{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "зїњеєХиІЖйҐСжЫњжНҐ",
  "version": "0.1.0",
  "identifier": "com.pangu.video-tihuan",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "зїњеєХиІЖйҐСжЫњжНҐ",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["../sidecars/video-tihuan-engine"]
  }
}

{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "video-tihuan-engine",
          "cmd": "video-tihuan-engine",
          "args": true,
          "sidecar": true
        }
      ]
    }
  ]
}

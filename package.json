{
  "name": "video-tihuan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "package:app": "npm run build:sidecar && npm run tauri build",
    "package:app:mac": "npm run build:sidecar && npm run tauri build -- --bundles dmg",
    "package:app:windows": "npm run build:sidecar && npm run tauri build -- --bundles nsis",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
